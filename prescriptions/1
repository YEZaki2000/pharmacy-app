import pytest
from django.contrib.auth import get_user_model
from rest_framework.test import APIClient
from rest_framework import status
from prescriptions.models import Prescription, PrescriptionItem
from inventory.models import Medicine, Category
from datetime import date

User = get_user_model()


@pytest.fixture
def api_client():
    return APIClient()


@pytest.fixture
def apotheker_user(db):
    return User.objects.create_user(
        username='apotheker',
        password='test123',
        role='pharmacist'
    )


@pytest.fixture
def klant_user(db):
    return User.objects.create_user(
        username='klant',
        password='test123',
        role='customer'
    )


@pytest.fixture
def medicijn(db):
    cat = Category.objects.create(naam='Test')
    return Medicine.objects.create(
        naam='Paracetamol',
        dosering='500mg',
        categorie=cat,
        prijs=5.00,
        voorraad=100,
        minimum_voorraad=20
    )


@pytest.mark.django_db
class TestPrescriptionAPI:
    
    def test_create_prescription_verlaagt_voorraad(
        self, api_client, apotheker_user, klant_user, medicijn
    ):
        """Bij aanmaken recept wordt voorraad automatisch verlaagd"""
        api_client.force_authenticate(user=apotheker_user)
        
        oude_voorraad = medicijn.voorraad
        
        data = {
            'klant': klant_user.id,
            'arts_naam': 'Dr. Test',
            'arts_telefoon': '0612345678',
            'datum': str(date.today()),
            'status': 'nieuw',
            'regels': [
                {
                    'medicijn': medicijn.id,
                    'hoeveelheid': 10,
                    'instructies': '2x per dag'
                }
            ]
        }
        
        response = api_client.post('/api/prescriptions/', data, format='json')
        
        assert response.status_code == status.HTTP_201_CREATED
        
        # Check dat voorraad is verlaagd
        medicijn.refresh_from_db()
        assert medicijn.voorraad == oude_voorraad - 10
    
    def test_klant_ziet_alleen_eigen_recepten(
        self, api_client, klant_user, apotheker_user
    ):
        """Klanten zien alleen hun eigen recepten"""
        # Maak recepten voor verschillende klanten
        Prescription.objects.create(
            klant=klant_user,
            arts_naam='Dr. A',
            datum=date.today(),
            status='nieuw'
        )
        
        andere_klant = User.objects.create_user(
            username='andere_klant',
            password='test123',
            role='customer'
        )
        Prescription.objects.create(
            klant=andere_klant,
            arts_naam='Dr. B',
            datum=date.today(),
            status='nieuw'
        )
        
        # Login als klant_user
        api_client.force_authenticate(user=klant_user)
        response = api_client.get('/api/prescriptions/')
        
        assert response.status_code == status.HTTP_200_OK
        assert response.data['count'] == 1
        assert response.data['results'][0]['arts_naam'] == 'Dr. A'
    
    def test_status_validatie(self, api_client, apotheker_user, klant_user):
        """Statusovergangen worden gevalideerd"""
        api_client.force_authenticate(user=apotheker_user)
        
        # Maak recept met status 'nieuw'
        prescription = Prescription.objects.create(
            klant=klant_user,
            arts_naam='Dr. Test',
            datum=date.today(),
            status='nieuw'
        )
        
        # Probeer direct naar 'uitgeleverd' te gaan (niet toegestaan)
        response = api_client.patch(
            f'/api/prescriptions/{prescription.id}/',
            {'status': 'uitgeleverd'}
        )
        
        assert response.status_code == status.HTTP_400_BAD_REQUEST
